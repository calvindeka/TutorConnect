{
  "name": "server",
  "version": "1.0.0",
  "description": "TutorConnect backend (Express + MariaDB + sessions)",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "db:schema": "mysql -u $DB_USER -p$DB_PASSWORD < schema.sql",
    "db:seed": "node scripts/seed.js",
    "db:reset": "npm run db:schema && npm run db:seed",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "Calvin Deka",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "mysql2": "^3.22.0"
  },
  "devDependencies": {
    "supertest": "^7.0.0",
    "vitest": "^2.1.5"
  }
}
